# This variable tells the system which model type you'll be using with D.A.N.T.E.
# You can choose from "OLLAMA_LOCAL", "OLLAMA_CLOUD", "OPENAI", "ANTHROPIC", and "OPENROUTER" for now.
# Want more? Try to make it yourself and submit a pr!

THINKING_MODEL_MODE = 

